# Notion Internal Integration Secret (notion.so/my-integrations 에서 발급)
# 발급 후 "훈련일지" 페이지에서 우측 상단 "..." -> "연결 추가"로 이 integration을 반드시 연결해야 함
NOTION_TOKEN=secret_xxx

# "훈련일지" 상위 페이지 ID (기본값이 이미 맞으므로 보통 수정 불필요)
NOTION_PARENT_PAGE_ID=2fb21ce8524480c8a52cc4e003e2dcdd

# 발신 Gmail 계정과 앱 비밀번호 (Google 계정 2단계 인증 -> 앱 비밀번호, 공백 없이 16자)
GMAIL_ADDRESS=studyhyunuk@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# 수신자
RECIPIENT_EMAIL=it.sanghun.yoo@gmail.com

# 메일 제목에 들어가는 발신자 표시 이름
SENDER_DISPLAY_NAME=김현욱

# (선택) 한글 폰트 경로를 직접 지정하고 싶을 때만 설정. 비워두면 자동 탐색.
# FONT_REGULAR=/usr/share/fonts/truetype/nanum/NanumGothic.ttf
# FONT_BOLD=/usr/share/fonts/truetype/nanum/NanumGothicBold.ttf
